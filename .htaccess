# ─── Deny access to setup, migration, and admin scripts ───
<FilesMatch "^(setup|_finish_setup|_fix_plans|_test_plan|_check|check_indexes|check_tables)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^migrate_.+\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^create_proposals_table\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "^_(test|debug|inspect|repair|fix|finish|verify).*\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ─── Deny access to database + log + env files ───
<FilesMatch "\.(db|sqlite|sqlite3|sql|bak|backup|log|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ─── Deny access to dotfiles ───
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# ─── Disable directory listing ───
Options -Indexes

# ─── PHP settings ───
<IfModule mod_php.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 64M
    php_value max_execution_time 300
</IfModule>
