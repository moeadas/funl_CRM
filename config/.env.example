# White Label CRM - Environment Configuration
# Copy this file to .env and fill in your values.
# All secrets should be generated with: php -r "echo bin2hex(random_bytes(32));"

# ─── App Encryption Key ───
# Used to encrypt sensitive tokens (SMTP passwords, OAuth tokens, Twilio auth tokens).
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# If not set, encryptToken() falls back to base64_encode (NOT secure).
APP_ENCRYPTION_KEY=

# ─── Twilio (VoIP + WhatsApp) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
WHATSAPP_FROM_NUMBER=

# ─── Resend (Email Campaigns) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# ─── Stripe (Billing) ───
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Microsoft 365 OAuth (Email) ───
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# ─── Google reCAPTCHA (Public form spam protection) ───
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── WordPress Marketing Site ───
# Set this to send logged-out users to your WordPress site instead of /register.php
MARKETING_URL=

# ─── Database ───
DB_HOST=localhost
DB_NAME=white_label_crm
DB_USER=
DB_PASS=

# ─── Trusted Reverse Proxies (L-3) ───
# Comma-separated IPs or CIDR ranges of reverse proxies / load balancers that
# sit in front of this app (e.g. Cloudflare, nginx, a LB). Only requests coming
# from these peers will have their X-Forwarded-For / X-Real-IP headers trusted
# for client-IP detection (used by rate limiting). Leave blank to trust only
# loopback + RFC1918 private ranges (safe default for single-host shared hosting).
# Example: TRUSTED_PROXIES=173.245.48.0/20,103.21.244.0/22,192.0.2.10
TRUSTED_PROXIES=

# ─── Rate Limiting Backend (L-8) ───
# IMPORTANT: rate limiting is file-based (stored in the system temp dir) and is
# therefore PER-APP-SERVER. It works correctly on single-server shared hosting
# (the intended target). If you deploy behind a load balancer across MULTIPLE
# app servers, limits are enforced independently per node — use sticky sessions,
# or replace the file store in includes/security.php with a shared Redis/DB
# backend so limits are global.
