# White Label CRM - Environment Configuration
# Copy this file to .env and fill in your values.
# All secrets should be generated with: php -r "echo bin2hex(random_bytes(32));"

# ─── App Encryption Key ───
# Used to encrypt sensitive tokens (SMTP passwords, OAuth tokens, Twilio auth tokens).
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# If not set, encryptToken() falls back to base64_encode (NOT secure).
APP_ENCRYPTION_KEY=

# ─── Twilio (VoIP + WhatsApp) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
WHATSAPP_FROM_NUMBER=

# ─── Resend (Email Campaigns) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# ─── Stripe (Billing) ───
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Microsoft 365 OAuth (Email) ───
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# ─── Google reCAPTCHA (Public form spam protection) ───
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── WordPress Marketing Site ───
# Set this to send logged-out users to your WordPress site instead of /register.php
MARKETING_URL=

# ─── Database ───
DB_HOST=localhost
DB_NAME=white_label_crm
DB_USER=
DB_PASS=
